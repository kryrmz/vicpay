# Copy to deploy/.env and fill with real values. NEVER commit deploy/.env.
# Generate strong secrets, e.g.:
#   openssl rand -base64 36        # for JWT_SECRET / PII_ENCRYPTION_KEY (>=32 bytes)
#   openssl rand -base64 24        # for database passwords

# Public site. Use a real domain for automatic HTTPS via Let's Encrypt.
# SITE_ADDRESS is what Caddy binds/certifies; SITE_ORIGIN is the scheme+host the
# browser sends as Origin (must match, used by the backend CSRF/CORS allowlist).
SITE_ADDRESS=vicpay.example.com
SITE_ORIGIN=https://vicpay.example.com

# Database passwords.
OWNER_DB_PASSWORD=change-me-owner
APP_DB_PASSWORD=change-me-app

# Application secrets (>= 32 bytes each).
JWT_SECRET=change-me-32-bytes-minimum-random-secret
PII_ENCRYPTION_KEY=change-me-32-bytes-minimum-random-key
