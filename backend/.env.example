# Copy to .env for local development. Never commit real secrets.

# development | staging | production. Anything but "development" activates
# ValidateForProduction, which refuses to boot with insecure defaults.
ENVIRONMENT=development
PORT=8080

# App pool: may route through PgBouncer (transaction mode).
DATABASE_URL=postgres://vicpay:vicpay_dev@localhost:6432/vicpay?sslmode=disable
# Direct pool: used ONLY for migrations and session advisory locks. Never point
# this at a transactional pooler.
DATABASE_DIRECT_URL=postgres://vicpay:vicpay_dev@localhost:5432/vicpay?sslmode=disable

# JWT signing secret. Production must be >= 32 random bytes.
JWT_SECRET=dev-secret-change-in-production-000

# App-layer PII encryption key (AES-256-GCM). Production must be >= 32 bytes and
# managed by a KMS/secret manager, never committed.
PII_ENCRYPTION_KEY=dev-pii-key-change-me-32bytes-min!

# Access/refresh token lifetimes.
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7
JWT_IDLE_MINUTES=30

# Comma-separated allowed browser origins (CORS + CSRF). No wildcard in prod.
CORS_ORIGINS=http://localhost:5173,http://localhost:9999

# Development only: log the OTP code so the flow works without a real SMS
# provider. ValidateForProduction refuses to boot if this is true outside dev.
OTP_DEV_ECHO=true

# Where the migration runner looks for *.sql files.
MIGRATIONS_DIR=./migrations
